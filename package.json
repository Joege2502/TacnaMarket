{
  "name": "tacna-market",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-server": "cd server && bun install --frozen-lockfile",
    "install-client": "cd client && bun install --frozen-lockfile",
    "install-all": "bun run install-server && bun run install-client",
    "build-client": "cd client && bun run build",
    "build-server": "cd server && bun run build",
    "build-all": "bun run build-client && bun run build-server"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "geoip-lite": "^1.4.10"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4"
  }
}